{
  "manifest_version": 3,
  "name": "RUDRAKSHA - Phishing Detection",
  "version": "1.1.0",
  "description": "Quick phishing URL scanning with RUDRAKSHA backend.",
  "permissions": ["activeTab", "tabs", "storage", "notifications"],
  "host_permissions": ["http://localhost:3000/*", "http://localhost:3001/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RUDRAKSHA"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
