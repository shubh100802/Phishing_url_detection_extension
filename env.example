# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/phishing-detection

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# API Keys (Get these from respective services)
GOOGLE_SAFE_BROWSING_API_KEY=your-google-safe-browsing-api-key
PHISHTANK_API_KEY=your-phishtank-api-key
OPENPHISH_API_KEY=your-openphish-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-key
SEED_ADMIN=false
SEED_ADMIN_NAME=Admin
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@rudraksha.local
SEED_ADMIN_PASSWORD=change-me-strong-password

# One-time reset script inputs
NEW_ADMIN_USERNAME=admin
NEW_ADMIN_EMAIL=admin@rudraksha.local
NEW_ADMIN_PASSWORD=change-me-strong-password

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Chrome Extension Configuration
EXTENSION_ID=your-chrome-extension-id
EXTENSION_SECRET=your-extension-secret-key
